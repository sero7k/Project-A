# Keep Docker build contexts free of local secrets, generated output, and RE artifacts.
.git/
.github/

# Python/cache
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# Virtual environments
.venv/
.venv*/
venv/
env/

# Packaging/build outputs
build/
dist/
*.egg-info/
pip-wheel-metadata/

# Local environment and secrets
.env
.env.*
!.env.example
*.crt
*.key
*.pem
*.bak-local-ca
*.p12
*.pfx

# Runtime output
logs/
reverse-logs/
*.log
*.jsonl

# Local-only client/dump/reversing artifacts
DUMP/
Dumper-7/
Project A Valorant/
findings/
AGENTS/
reference/
reverse_tools/
SDK/
GeneratedSDK/
*.exe
*.dll
*.pak
*.sig
*.i64
*.idb
*.id0
*.id1
*.id2
*.nam
*.til
*.pdb
*.dmp
*.bin
*.sys

# Editor/OS noise
.vscode/
.idea/
.DS_Store
Thumbs.db
